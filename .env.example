# SigNoz Cloud Frontend Tracing Configuration
# Find these in SigNoz Cloud: Settings -> Ingestion Settings -> Instrumentation Keys

# SigNoz OTLP HTTP Endpoint (e.g., https://ingest.us2.signoz.cloud)
# Get this from Settings -> Ingestion Settings in your SigNoz Cloud dashboard
VITE_SIGNOZ_ENDPOINT=https://ingest.us2.signoz.cloud

# SigNoz Ingestion Key
# Get this from Settings -> Ingestion Settings in your SigNoz Cloud dashboard
VITE_SIGNOZ_INGESTION_KEY=YOUR_SIGNOZ_INGESTION_KEY

# Application Name (default: lfcrea-frontend)
VITE_APP_NAME=lfcrea-frontend

# Supabase
# Find these in your Supabase project: Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# MinIO Media Storage
# Public-facing base URL of the MinIO instance — no trailing slash
# Portfolio items can store either a full URL or a relative path; relative paths are resolved against this base
VITE_MINIO_PUBLIC_URL=https://media.lfcrea.com
